{
  "name": "@fast-check/cli",
  "description": "CLI to setup fast-check within your project: detects test framework, installs the right extension, and configures timeouts",
  "version": "0.0.0",
  "type": "module",
  "exports": {
    "./package.json": "./package.json",
    ".": "./lib/cli.js"
  },
  "bin": "./bin/setup.js",
  "files": [
    "bin",
    "lib"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "rolldown -c",
    "build-ci": "rolldown -c",
    "typecheck": "tsc --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dubzzz/fast-check.git",
    "directory": "packages/cli"
  },
  "author": "Nicolas DUBIEN <github@dubien.org>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/dubzzz/fast-check/issues"
  },
  "homepage": "https://github.com/dubzzz/fast-check/tree/main/packages/cli#readme",
  "engines": {
    "node": ">=20.19.0"
  },
  "devDependencies": {
    "@types/node": "^24.12.0",
    "rolldown": "^1.0.0-rc.11",
    "typescript": "~5.9.3",
    "vitest": "^4.1.0"
  },
  "keywords": [
    "fast-check",
    "setup",
    "cli",
    "property-based testing",
    "testing"
  ],
  "funding": [
    {
      "type": "individual",
      "url": "https://github.com/sponsors/dubzzz"
    },
    {
      "type": "opencollective",
      "url": "https://opencollective.com/fast-check"
    }
  ]
}
